<?xml version="1.0" encoding="utf-8"?>
<!--Jasdeep Cheema waitlist count number screen-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">


    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#6200EE"
        android:elevation="4dp"
        app:titleTextColor="@android:color/white" />



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">


        <TextView
            android:id="@+id/lottery_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="5dp"
            android:text="Criteria: Random draw from waiting list."
            android:textStyle="italic"
            android:textSize="14sp" />


        <TextView
            android:id="@+id/user_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="15dp"
            android:text="Your Status: Loading..."
            android:textSize="22sp"
            android:textStyle="bold" />


        <TextView
            android:id="@+id/waiting_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="25dp"
            android:text="Waiting List: 0"
            android:textSize="18sp" />


        <Button
            android:id="@+id/accept_invite"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#4CAF50"
            android:text="Accept Invitation"
            android:visibility="gone" />


        <Button
            android:id="@+id/decline_invite"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#F44336"
            android:text="Decline Invitation"
            android:visibility="gone" />


    </LinearLayout>
</LinearLayout>
