<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/backgroundGray">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/event_qr_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primaryPurple"
        android:elevation="4dp"
        app:title="@string/create_event_title"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@android:color/white"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:id="@+id/event_qr_instruction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/event_qr_instruction"
                android:textSize="16sp"
                android:textColor="#666666"
                android:lineSpacingMultiplier="1.2"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="24dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="6dp"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:id="@+id/event_qr_image"
                    android:layout_width="280dp"
                    android:layout_height="280dp"
                    android:contentDescription="@string/event_qr_content_description"
                    android:scaleType="fitCenter"
                    android:padding="16dp"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/event_qr_success_message"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/textDark"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="32dp"/>

            <Button
                android:id="@+id/event_qr_download"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/download_qr"
                android:background="@drawable/button_outline_purple"
                android:textColor="@color/primaryPurple"/>

            <Button
                android:id="@+id/event_qr_done"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/done"
                android:background="@drawable/button_primary_purple"
                android:textColor="@android:color/white"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
