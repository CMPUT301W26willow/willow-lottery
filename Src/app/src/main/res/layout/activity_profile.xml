<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundGray">

    <ScrollView
        android:id="@+id/profile_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_nav"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/profile_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_title"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/textDark"
                android:layout_marginBottom="16dp"/>

            <ImageView
                android:id="@+id/profile_avatar"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/circle_primary"
                android:padding="14dp"
                android:src="@drawable/baseline_person_24"
                android:tint="@android:color/white"
                android:contentDescription="@string/profile_title"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_name_label"
                android:textColor="@color/textDark"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/nameInput"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="@string/profile_name_hint"
                android:textColor="@color/textDark"
                android:textColorHint="#888888"
                android:padding="12dp"
                android:background="@drawable/input_background"
                android:layout_marginBottom="14dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_email_label"
                android:textColor="@color/textDark"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/emailInput"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="@string/profile_email_hint"
                android:textColor="@color/textDark"
                android:textColorHint="#888888"
                android:inputType="textEmailAddress"
                android:padding="12dp"
                android:background="@drawable/input_background"
                android:layout_marginBottom="14dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile_phone_label"
                android:textColor="@color/textDark"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/phoneInput"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="@string/profile_phone_hint"
                android:textColor="@color/textDark"
                android:textColorHint="#888888"
                android:inputType="phone"
                android:padding="12dp"
                android:background="@drawable/input_background"
                android:layout_marginBottom="20dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <Button
                    android:id="@+id/saveButton"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="@string/profile_save_changes"
                    android:textColor="@android:color/white"
                    android:background="@drawable/button_primary_purple"
                    android:layout_marginEnd="12dp"/>

                <Button
                    android:id="@+id/cancelButton"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:text="@string/profile_cancel"
                    android:textColor="@color/primaryPurple"
                    android:background="@drawable/button_outline_purple"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:elevation="4dp"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/organizer_dashboard_title"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/textDark"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/organizer_dashboard_body"
                    android:textColor="#666666"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/organizerDashboardButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="@string/organizer_dashboard_button"
                    android:textColor="@android:color/white"
                    android:background="@drawable/button_primary_purple"/>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:background="@android:color/white"
        app:itemIconTint="@color/primaryPurple"
        app:itemTextColor="@color/primaryPurple"
        app:menu="@menu/bottom_menu"/>

</RelativeLayout>