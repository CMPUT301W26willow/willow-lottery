<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    card_view:cardCornerRadius="12dp"
    card_view:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/admin_profile_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="User Name"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#111111" />

        <TextView
            android:id="@+id/admin_profile_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="user@email.com"
            android:textSize="14sp"
            android:textColor="#555555" />

        <TextView
            android:id="@+id/admin_profile_role"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Organizer"
            android:textSize="13sp"
            android:textColor="#666666" />

        <Button
            android:id="@+id/admin_remove_organizer_button"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="14dp"
            android:text="Remove Organizer Privileges"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/admin_delete_profile_button"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="10dp"
            android:text="Delete Profile"
            android:textAllCaps="false" />

    </LinearLayout>
</androidx.cardview.widget.CardView>