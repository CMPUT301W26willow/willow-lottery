<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundGray"
    android:padding="24dp">

    <TextView
        android:id="@+id/accepted_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/organizer_enrolled_entrants_title"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/textDark" />

    <TextView
        android:id="@+id/accepted_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/accepted_title"
        android:layout_marginTop="24dp"
        android:text="@string/organizer_no_enrolled_entrants"
        android:textColor="#666666"
        android:visibility="gone" />

    <ListView
        android:id="@+id/acceptedListView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/accepted_title"
        android:layout_above="@id/accepted_back_button"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/accepted_back_button"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_alignParentBottom="true"
        android:text="Back"
        android:textColor="@android:color/white"
        android:backgroundTint="@color/buttonBlue" />

</RelativeLayout>
