<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/backgroundGray">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/event_detail_toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/toolbarDark"
        android:elevation="4dp"
        app:title="@string/event_detail_title"
        app:titleTextColor="@android:color/white"
        app:navigationIcon="?attr/homeAsUpIndicator"
        app:navigationIconTint="@android:color/white"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="@color/backgroundGray">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Poster at top, full width -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:background="@color/borderGray">

                <ImageView
                    android:id="@+id/event_detail_poster"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="@string/event_poster"
                    android:visibility="gone"/>

                <View
                    android:id="@+id/event_detail_poster_placeholder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/borderGray"/>
            </FrameLayout>

            <!-- White card content -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="-16dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/event_detail_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/textDark"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:lineSpacingExtra="2dp"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/event_detail_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#666666"
                        android:textSize="15sp"
                        android:lineSpacingExtra="4dp"
                        android:layout_marginBottom="16dp"/>

                    <!-- Organizer -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <ImageView
                            android:id="@+id/event_detail_icon_organizer"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            app:srcCompat="@drawable/baseline_person_24"
                            app:tint="@color/iconGray"
                            android:contentDescription="@null"/>
                        <TextView
                            android:id="@+id/event_detail_organizer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:textColor="#666666"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <!-- Event date -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">
                        <ImageView
                            android:id="@+id/event_detail_icon_date"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            app:srcCompat="@drawable/baseline_event_24"
                            app:tint="@color/iconGray"
                            android:contentDescription="@null"/>
                        <TextView
                            android:id="@+id/event_detail_date"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:textColor="#666666"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <!-- Registration period -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="10dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <ImageView
                                android:id="@+id/event_detail_icon_registration"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                app:srcCompat="@drawable/outline_arming_countdown_24"
                                app:tint="@color/iconGray"
                                android:contentDescription="@null"/>
                            <TextView
                                android:id="@+id/event_detail_registration_dates"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:textColor="#666666"
                                android:textSize="14sp"/>
                        </LinearLayout>
                        <TextView
                            android:id="@+id/event_detail_registration_opens"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="36dp"
                            android:layout_marginTop="2dp"
                            android:textColor="#999999"
                            android:textSize="13sp"/>
                    </LinearLayout>

                    <!-- Waiting list info -->
                    <TextView
                        android:id="@+id/event_detail_waiting_list"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/textDark"
                        android:textSize="14sp"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:id="@+id/event_detail_limit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#666666"
                        android:textSize="13sp"
                        android:layout_marginBottom="16dp"/>

                    <!-- Lottery criteria -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/event_detail_lottery_criteria"
                        android:textColor="@color/textDark"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:layout_marginBottom="8dp"/>
                    <TextView
                        android:id="@+id/event_detail_lottery_bullets"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#666666"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"
                        android:layout_marginBottom="24dp"/>

                    <Button
                        android:id="@+id/event_detail_join_leave_btn"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/button_primary_blue"
                        android:textColor="@android:color/white"
                        android:textAllCaps="false"
                        android:textSize="16sp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
