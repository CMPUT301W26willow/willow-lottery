<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="20dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">


    <TextView
        android:id="@+id/lottery_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:text="Lottery Information"
        android:textSize="20sp"
        android:layout_marginTop="100dp"/>

    <TextView
        android:id="@+id/waiting_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp"
        android:text="Waiting List: 0"
        android:textSize="18sp"
        android:layout_marginTop="100dp"/>

    <Button
        android:id="@+id/accept_invite"
        android:text="Accept Invitation"
        android:visibility="gone"
        android:backgroundTint="#4CAF50"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>


    <Button
        android:id="@+id/decline_invite"
        android:text="Decline Invitation"
        android:visibility="gone"
        android:backgroundTint="#F44336"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>
</LinearLayout>
