<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundGray"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit Event"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/textDark"
            android:layout_marginBottom="24dp"/>

        <ImageView
            android:id="@+id/eventPosterImageView"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:src="@drawable/event_placeholder_1"
            android:contentDescription="@string/event_poster"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/uploadPosterButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Upload Event Poster"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/buttonBlue"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:id="@+id/uploadStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/primaryPurple"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/backButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Back"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/buttonBlue"/>

    </LinearLayout>
</ScrollView>