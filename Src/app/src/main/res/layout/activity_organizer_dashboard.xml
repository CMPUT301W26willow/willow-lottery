<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundGray">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/organizer_dashboard_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/organizer_dashboard_screen_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/textDark"/>

        <TextView
            android:id="@+id/organizer_dashboard_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/organizer_dashboard_screen_body"
            android:textColor="#666666"/>

        <Button
            android:id="@+id/createEventButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:text="@string/create_event"
            android:textColor="@android:color/white"
            android:background="@drawable/button_primary_purple"/>

        <TextView
            android:id="@+id/waitingListLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Waiting List"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/textDark"/>

        <TextView
            android:id="@+id/lotteryControlsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Maximum nb of Attendees"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/textDark"/>

        <EditText
            android:id="@+id/drawSizeInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:hint="Draw size"
            android:inputType="number"
            android:background="@drawable/input_background"
            android:padding="12dp"
            android:textColor="@color/textDark"
            android:textColorHint="#888888"/>

        <LinearLayout
            android:id="@+id/lotteryButtonsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/runLotteryButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Run Lottery"
                android:textColor="@android:color/white"
                android:background="@drawable/button_primary_purple"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/drawReplacementButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Draw Replacement"
                android:textColor="@color/primaryPurple"
                android:background="@drawable/button_outline_purple"/>
        </LinearLayout>

        <ListView
            android:id="@+id/waitingListView"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/notifyWaitlistButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:text="Notify Waiting List"
            android:textColor="@android:color/white"
            android:background="@drawable/button_primary_purple"/>

        <Button
            android:id="@+id/exportEntrantsCsvButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:text="Export Entrants CSV"
            android:textColor="@android:color/white"
            android:background="@drawable/button_primary_purple"/>

        <Button
            android:id="@+id/viewInvitedButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:text="Cancel Invited Entrants"
            android:textColor="@android:color/white"
            android:background="@drawable/button_primary_purple"/>

        <Button
            android:id="@+id/viewCancelledButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:text="View Cancelled Entrants"
            android:textColor="@android:color/white"
            android:background="@drawable/button_primary_purple"/>

        <LinearLayout
            android:id="@+id/geolocationRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Require Geolocation"
                android:textSize="16sp"
                android:textColor="@color/textDark"/>

            <Switch
                android:id="@+id/geolocationSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <Button
            android:id="@+id/viewMapButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:text="View Entrant Map"
            android:textColor="@android:color/white"
            android:background="@drawable/button_primary_purple"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Search &amp; Invite Entrants"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/textDark"/>

        <EditText
            android:id="@+id/searchEntrantInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:hint="Search by name, email, or phone"
            android:background="@drawable/input_background"
            android:padding="12dp"
            android:textColor="@color/textDark"
            android:textColorHint="#888888"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/searchEntrantButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Search"
                android:textColor="@android:color/white"
                android:background="@drawable/button_primary_purple"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/inviteEntrantButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Invite"
                android:textColor="@android:color/white"
                android:background="@drawable/button_primary_purple"/>

        </LinearLayout>

        <ListView
            android:id="@+id/searchResultsListView"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/backToProfileButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:text="@string/back_to_profile"
            android:textColor="@android:color/white"
            android:background="@drawable/button_primary_purple"/>

    </LinearLayout>
</ScrollView>