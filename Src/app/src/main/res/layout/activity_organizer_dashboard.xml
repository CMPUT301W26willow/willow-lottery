<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundGray"
    android:fillViewport="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/organizer_dashboard_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/organizer_dashboard_screen_title"
            android:textColor="@color/textDark"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/organizer_dashboard_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/organizer_dashboard_screen_body"
            android:textColor="#666666" />

        <Button
            android:id="@+id/createEventButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/button_primary_purple"
            android:text="@string/create_event"
            android:textColor="@android:color/white" />

        <TextView
            android:id="@+id/waitingListLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Waiting List"
            android:textColor="@color/textDark"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/exportEntrantsCsvButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/button_outline_purple"
            android:text="@string/organizer_export_entrants_csv"
            android:textColor="@color/primaryPurple" />

        <TextView
            android:id="@+id/lotteryControlsLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Lottery Controls"
            android:textColor="@color/textDark"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/drawSizeInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/input_background"
            android:hint="Draw size"
            android:inputType="number"
            android:padding="12dp"
            android:textColor="@color/textDark"
            android:textColorHint="#888888" />

        <LinearLayout
            android:id="@+id/lotteryButtonsRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/runLotteryButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/button_primary_purple"
                android:text="Run Lottery"
                android:textColor="@android:color/white" />

            <Button
                android:id="@+id/drawReplacementButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/button_outline_purple"
                android:text="Draw Replacement"
                android:textColor="@color/primaryPurple" />
        </LinearLayout>

        <ListView
            android:id="@+id/waitingListView"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/input_background"
            android:divider="@android:color/darker_gray"
            android:dividerHeight="1dp"
            android:nestedScrollingEnabled="true" />

        <LinearLayout
            android:id="@+id/privateInviteSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@android:color/white"
            android:elevation="2dp"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Private Event Invites"
                android:textColor="@color/textDark"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/searchEntrantInput"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_background"
                android:hint="Search by name, phone, or email"
                android:padding="12dp"
                android:textColor="@color/textDark"
                android:textColorHint="#888888" />

            <Button
                android:id="@+id/searchEntrantButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/button_primary_purple"
                android:text="Search Entrants"
                android:textColor="@android:color/white" />

            <ListView
                android:id="@+id/searchResultsListView"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_background"
                android:divider="@android:color/darker_gray"
                android:dividerHeight="1dp"
                android:nestedScrollingEnabled="true" />

            <Button
                android:id="@+id/inviteEntrantButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/button_primary_purple"
                android:text="Invite Selected Entrant"
                android:textColor="@android:color/white" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/geolocationRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Require Geolocation"
                android:textColor="@color/textDark"
                android:textSize="16sp" />

            <Switch
                android:id="@+id/geolocationSwitch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <Button
            android:id="@+id/viewMapButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/button_primary_purple"
            android:text="View Entrant Map"
            android:textColor="@android:color/white" />

        <Button
            android:id="@+id/backToProfileButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/button_primary_purple"
            android:text="@string/back_to_profile"
            android:textColor="@android:color/white" />
    </LinearLayout>
</ScrollView>
