<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundGray"
    android:padding="24dp">

    <TextView
        android:id="@+id/organizer_dashboard_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/organizer_dashboard_screen_title"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/textDark"/>

    <TextView
        android:id="@+id/organizer_dashboard_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/organizer_dashboard_title"
        android:layout_marginTop="12dp"
        android:text="@string/organizer_dashboard_screen_body"
        android:textColor="#666666"/>

    <Button
        android:id="@+id/createEventButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_below="@id/organizer_dashboard_body"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:text="@string/create_event"
        android:textColor="@android:color/white"
        android:background="@drawable/button_primary_purple"/>

    <TextView
        android:id="@+id/waitingListLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/createEventButton"
        android:layout_marginTop="8dp"
        android:text="Waiting List"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/textDark"/>

    <TextView
        android:id="@+id/lotteryControlsLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/waitingListLabel"
        android:layout_marginTop="12dp"
        android:text="Lottery Controls"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/textDark"/>

    <EditText
        android:id="@+id/drawSizeInput"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_below="@id/lotteryControlsLabel"
        android:layout_marginTop="8dp"
        android:hint="Draw size"
        android:inputType="number"
        android:background="@drawable/input_background"
        android:padding="12dp"
        android:textColor="@color/textDark"
        android:textColorHint="#888888"/>

    <LinearLayout
        android:id="@+id/lotteryButtonsRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/drawSizeInput"
        android:layout_marginTop="10dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/runLotteryButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Run Lottery"
                android:textColor="@android:color/white"
                android:background="@drawable/button_primary_purple"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/drawReplacementButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Draw Replacement"
                android:textColor="@color/primaryPurple"
                android:background="@drawable/button_outline_purple"/>

        </LinearLayout>

        <Button
            android:id="@+id/notifyWaitlistButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Notify Waiting List"
            android:textColor="@color/primaryPurple"
            android:background="@drawable/button_outline_purple"/>

    </LinearLayout>


</RelativeLayout>