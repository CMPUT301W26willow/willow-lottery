<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    card_view:cardCornerRadius="12dp"
    card_view:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <ImageView
            android:id="@+id/admin_image_preview"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:scaleType="centerCrop"
            android:src="@drawable/event_placeholder_1" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/admin_image_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Event Poster"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#111111" />

            <TextView
                android:id="@+id/admin_image_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="2026-04-05"
                android:textSize="13sp"
                android:textColor="#666666" />

            <Button
                android:id="@+id/admin_remove_image_button"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="12dp"
                android:text="Remove Image"
                android:textAllCaps="false" />

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>