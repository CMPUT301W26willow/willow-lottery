<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundGray">

    <TextView
        android:id="@+id/events_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:text="Events"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/textDark"/>

    <SearchView
        android:id="@+id/events_search"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/events_title"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:iconifiedByDefault="false"
        android:queryHint="Search events..."/>
    <HorizontalScrollView
        android:id="@+id/filter_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/events_search"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/filter_open"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Open"
                android:textSize="13sp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/button_outline_purple"
                android:textColor="@color/primaryPurple"/>

            <Button
                android:id="@+id/filter_available"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Spots Available"
                android:textSize="13sp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/button_outline_purple"
                android:textColor="@color/primaryPurple"/>

            <Button
                android:id="@+id/filter_date"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="By Date"
                android:textSize="13sp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/button_outline_purple"
                android:textColor="@color/primaryPurple"/>

            <Button
                android:id="@+id/filter_clear"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Clear"
                android:textSize="13sp"
                android:background="@drawable/button_outline_purple"
                android:textColor="@color/primaryPurple"/>

        </LinearLayout>

    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/events_recycler"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/filter_scroll"
        android:layout_above="@id/bottom_nav"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/events_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="gone"
        android:text="No events yet"
        android:textSize="16sp"
        android:textColor="@color/textGray" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="88dp"
        android:layout_alignParentBottom="true"
        android:background="@android:color/white"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        app:itemIconSize="22dp"
        app:itemIconTint="@color/primaryPurple"
        app:itemTextColor="@color/primaryPurple"
        app:menu="@menu/bottom_menu"/>

</RelativeLayout>